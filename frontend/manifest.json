{
    "manifest_version": 3,
    "name": "Clipmark",
    "version": "1.0",
    "description": "Bookmark, tag, and revisit YouTube moments with AI-powered notes and cloud sync.",
    "permissions": ["storage", "tabs", "activeTab", "scripting"],
    "host_permissions": [
        "*://www.youtube.com/*",
        "http://localhost:3000/*",
        "https://clipmark-chi.vercel.app/*"
    ],
    "web_accessible_resources": [{
      "resources": ["bookmarks.html", "bookmarks.js", "bookmarks.css"],
      "matches": ["<all_urls>"]
    }],
    "action": {
      "default_popup": "popup.html",
      "default_icon": {
        "16": "icon-16.png",
        "48": "icon-48.png",
        "128": "icon-128.png"
      }
    },
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["*://*.youtube.com/*"],
        "js": ["content.js"],
        "run_at": "document_end",
        "css": []
      }
    ],
    "commands": {
      "_execute_action": {
        "suggested_key": {
          "default": "Alt+B"
        },
        "description": "Open bookmark popup"
      },
      "quick_save": {
        "suggested_key": {
          "default": "Ctrl+Shift+S",
          "mac": "Command+Shift+S"
        },
        "description": "Quick save bookmark"
      },
      "silent_save": {
        "suggested_key": {
          "default": "Alt+S"
        },
        "description": "Silent save bookmark"
      }
    },
    "icons": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    },
    "externally_connectable": {
      "matches": [
        "http://localhost:3000/*",
        "https://clipmark-chi.vercel.app/*"
      ]
    }
}
