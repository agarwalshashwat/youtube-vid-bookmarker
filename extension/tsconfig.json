{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@clipmark/core": ["../packages/core/src/index.ts"],
      "@clipmark/types": ["../packages/types/src/index.ts"]
    }
  },
  "include": ["src/side-panel", "src/dashboard", "src/shared", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
