# ─── YouTube Video Bookmarker — Environment Variables ─────────────────────────
#
# Setup steps:
#   1. Copy this file:  cp .env.sample .env.local
#   2. Fill in the values below
#   3. Restart the dev server:  npm run dev
#
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these at: https://supabase.com → your project → Settings → API
#
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── App URL ───────────────────────────────────────────────────────────────────
# Used to construct OAuth redirect URIs and shared page links.
# Local dev:   http://localhost:3000
# Production:  https://bookmarker.app  (or your Vercel URL)
#
NEXT_PUBLIC_APP_URL=http://localhost:3000
