# ─── Clipmark — Environment Variables ────────────────────────────────────────
#
# Setup:
#   cp .env.example .env
#   Fill in the values below, then: npm run dev
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Settings → API → service_role (used by webhooks + migration runner)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Settings → Database → Connection string → URI, Session mode pooler (port 5432)
# Used by: npm run migrate (runs automatically before every build)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── App ───────────────────────────────────────────────────────────────────────
# Local dev: http://localhost:3000  |  Production: your Vercel URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Anthropic ─────────────────────────────────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Dodo Payments ─────────────────────────────────────────────────────────────
# https://app.dodopayments.com → Settings → API Keys
DODO_PAYMENTS_API_KEY=your-dodo-api-key-here
# https://app.dodopayments.com → Webhooks → your endpoint → signing secret
DODO_PAYMENTS_WEBHOOK_SECRET=your-webhook-secret-here
# Product IDs — create these in the Dodo dashboard under Products
DODO_MONTHLY_PRODUCT_ID=your-monthly-product-id
DODO_ANNUAL_PRODUCT_ID=your-annual-product-id
DODO_LIFETIME_PRODUCT_ID=your-lifetime-product-id
