# Supabase project settings
# Get these from: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Anthropic API key (for AI Summary + Smart Tagging — Phase 4.2/4.3)
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Supabase service role key (for webhook handler to update profiles)
# Get from: https://supabase.com → your project → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Dodo Payments (Phase 7 — Monetization)
# Get from: https://app.dodopayments.com → Settings → API Keys
DODO_PAYMENTS_API_KEY=your-dodo-api-key-here
# Get from: https://app.dodopayments.com → Webhooks → your endpoint → signing secret
DODO_PAYMENTS_WEBHOOK_SECRET=your-webhook-secret-here
# Product IDs — create these in the Dodo dashboard under Products
DODO_MONTHLY_PRODUCT_ID=your-monthly-product-id
DODO_ANNUAL_PRODUCT_ID=your-annual-product-id
DODO_LIFETIME_PRODUCT_ID=your-lifetime-product-id
